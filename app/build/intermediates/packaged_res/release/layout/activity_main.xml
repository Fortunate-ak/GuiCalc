<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    ==================
    Layout demonstrating TWO layout managers (Lab 1 requirement):

    [1] ConstraintLayout — root container. Positions the display area
        at the top and the button grid at the bottom using constraints.

    [2] GridLayout — organises the calculator buttons in a 5-row × 4-column
        grid. Each button declares its row and column span explicitly.

    All styling (colors, fonts) is applied in MainActivity.java so you can
    see both approaches: XML layout structure + Java styling.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <!-- ===================================================== -->
    <!-- DISPLAY AREA                                           -->
    <!-- ===================================================== -->
    <LinearLayout
        android:id="@+id/layout_display"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/grid_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_weight="0.35">

        <!-- Expression hint: e.g. "12 +" -->
        <TextView
            android:id="@+id/tv_expression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:gravity="end"
            android:fontFamily="sans-serif" />

        <!-- Main number display -->
        <TextView
            android:id="@+id/tv_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="52sp"
            android:gravity="end"
            android:fontFamily="sans-serif-light"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Active operator indicator -->
        <TextView
            android:id="@+id/tv_operator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="20sp"
            android:gravity="end"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- ===================================================== -->
    <!-- BUTTON GRID — GridLayout (Layout Manager #2)          -->
    <!-- 5 rows × 4 columns                                    -->
    <!-- ===================================================== -->
    <GridLayout
        android:id="@+id/grid_buttons"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="8dp"
        android:useDefaultMargins="true"
        app:layout_constraintTop_toBottomOf="@id/layout_display"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_weight="0.65">

        <!-- ROW 0: AC | +/- | % | DEL -->
        <Button
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="AC"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_column="0"
            android:layout_row="0"
            style="@style/CalcButton" />

        <Button
            android:id="@+id/btn_sign"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="+/-"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_column="1"
            android:layout_row="0"
            style="@style/CalcButton" />

        <Button
            android:id="@+id/btn_percent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="%"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_column="2"
            android:layout_row="0"
            style="@style/CalcButton" />

        <Button
            android:id="@+id/btn_del"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="⌫"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_column="3"
            android:layout_row="0"
            style="@style/CalcButton" />

        <!-- ROW 1: 7 | 8 | 9 | ÷ -->
        <Button android:id="@+id/btn_7" android:text="7"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="0" android:layout_row="1" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_8" android:text="8"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="1" android:layout_row="1" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_9" android:text="9"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="2" android:layout_row="1" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_div" android:text="÷"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="3" android:layout_row="1" style="@style/CalcButton"/>

        <!-- ROW 2: 4 | 5 | 6 | × -->
        <Button android:id="@+id/btn_4" android:text="4"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="0" android:layout_row="2" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_5" android:text="5"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="1" android:layout_row="2" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_6" android:text="6"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="2" android:layout_row="2" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_mul" android:text="×"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="3" android:layout_row="2" style="@style/CalcButton"/>

        <!-- ROW 3: 1 | 2 | 3 | - -->
        <Button android:id="@+id/btn_1" android:text="1"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="0" android:layout_row="3" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_2" android:text="2"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="1" android:layout_row="3" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_3" android:text="3"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="2" android:layout_row="3" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_sub" android:text="−"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="3" android:layout_row="3" style="@style/CalcButton"/>

        <!-- ROW 4: 0 | . | + | = -->
        <Button android:id="@+id/btn_0" android:text="0"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="0" android:layout_row="4"
            style="@style/CalcButton"/>

        <Button android:id="@+id/btn_dot" android:text="."
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="1" android:layout_row="4" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_add" android:text="+"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="2" android:layout_row="4" style="@style/CalcButton"/>

        <Button android:id="@+id/btn_equals" android:text="="
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_column="3" android:layout_row="4" style="@style/CalcButton"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
