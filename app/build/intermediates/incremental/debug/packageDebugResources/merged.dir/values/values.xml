<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg_action">#533483</color>
    <color name="bg_digit">#16213E</color>
    <color name="bg_display">#1A1A2E</color>
    <color name="bg_equals">#E94560</color>
    <color name="bg_operator">#0F3460</color>
    <color name="bg_primary">#0D0D1A</color>
    <color name="colorPrimaryDark">#0D0D1A</color>
    <color name="text_action">#FFFFFF</color>
    <color name="text_digit">#E0E0E0</color>
    <color name="text_equals">#FFFFFF</color>
    <color name="text_operator">#E94560</color>
    <color name="text_primary">#FFFFFF</color>
    <color name="text_secondary">#9E9E9E</color>
    <string name="app_name">GuiCalc</string>
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/bg_operator</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/bg_equals</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
    </style>
    <style name="Base.Theme.GuiCalc" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
    </style>
    <style name="CalcButton">
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_digit</item>
        <item name="android:background">@color/bg_digit</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="Theme.GuiCalc" parent="Base.Theme.GuiCalc"/>
</resources>